# Copy to .env and fill in. Local Docker defaults shown.
PGHOST=localhost
PGPORT=5432
PGDATABASE=mfpulse
PGUSER=mfpulse
PGPASSWORD=mfpulse

# For a hosted DB (e.g. Supabase), set a single URL instead — it wins over the PG* vars:
# DATABASE_URL=postgresql://user:pass@host:5432/postgres

# Airflow / alerting (Phase 2)
SLACK_WEBHOOK_URL=
